{
  "name": "@app/server",
  "version": "1.0.0",
  "description": "A Fastify template project",
  "main": "src/main.ts",
  "directories": {
    "test": "test"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/src/main.js",
    "test": "NODE_ENV=test tsx --test --test-concurrency=1 test/**/*.test.js --timeout 5000",
    "test:auth": "NODE_ENV=test tsx --test test/auth.test.js",
    "test:user": "NODE_ENV=test tsx --test test/user.test.js",
    "test:chat": "NODE_ENV=test tsx --test test/chat.test.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "lint:check": "eslint . --max-warnings 0",
    "migrate:up": "tsx db/migrate.ts up",
    "migrate:down": "tsx db/migrate.ts down",
    "migrate:status": "tsx db/migrate.ts status",
    "migrate:create": "tsx db/migrate.ts create",
    "migrate:redo": "tsx db/migrate.ts redo",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.879.0",
    "@aws-sdk/s3-request-presigner": "^3.879.0",
    "@fastify/autoload": "^6.0.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "dotenv": "^17.2.1",
    "fastify": "^5.0.0",
    "fastify-cli": "^7.4.0",
    "fastify-plugin": "^5.0.0",
    "firebase-admin": "^13.5.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.15.5",
    "@types/ws": "^8.18.1",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.33.0",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jiti": "^2.5.1",
    "json-schema-to-ts": "^3.1.1",
    "node-pg-migrate": "^8.0.3",
    "nodemon": "^3.1.10",
    "prettier": "3.6.2",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.1"
  }
}
