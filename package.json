{
  "name": "fastify-template",
  "version": "1.0.0",
  "description": "A Fastify template project",
  "main": "src/main.ts",
  "directories": {
    "test": "test"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/main.js",
    "test": "node test/run-all-tests.js",
    "test:auth": "tsx --test test/auth.test.js",
    "test:user": "tsx --test test/user.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:check": "eslint . --max-warnings 0",
    "migrate": "npx dotenv -e .env -- node-pg-migrate --migrations-dir db/migrations --tsx",
    "migrate:up": "npx dotenv -e .env -- node-pg-migrate up --migrations-dir db/migrations --tsx",
    "migrate:down": "npx dotenv -e .env -- node-pg-migrate down --migrations-dir db/migrations --tsx",
    "migrate:create": "npx dotenv -e .env -- node-pg-migrate create --migrations-dir db/migrations --tsx",
    "migrate:redo": "npx dotenv -e .env -- node-pg-migrate redo --migrations-dir db/migrations --tsx"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/autoload": "^6.0.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "dotenv": "^17.2.1",
    "fastify": "^5.0.0",
    "fastify-cli": "^7.4.0",
    "fastify-plugin": "^5.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.15.5",
    "@types/ws": "^8.18.1",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.33.0",
    "globals": "^16.3.0",
    "jiti": "^2.5.1",
    "json-schema-to-ts": "^3.1.1",
    "node-pg-migrate": "^8.0.3",
    "nodemon": "^3.1.10",
    "prettier": "3.6.2",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.1"
  }
}
