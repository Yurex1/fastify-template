{
  "name": "fastify-template",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @fastify-template/client dev\" \"pnpm --filter @fastify-template/server dev\"",
    "dev:client": "pnpm --filter @fastify-template/client dev",
    "dev:server": "pnpm --filter @fastify-template/server dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "lint:client": "pnpm --filter @fastify-template/client lint",
    "lint:server": "pnpm --filter @fastify-template/server lint",
    "clean": "rm -rf node_modules apps/*/node_modules"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "eslint": "^9.39.4",
    "@eslint/js": "^9.39.4",
    "typescript-eslint": "^8.58.0",
    "globals": "^15.15.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19"
  }
}
